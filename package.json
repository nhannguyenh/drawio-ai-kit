{
  "name": "drawio-ai-kit",
  "version": "0.1.0",
  "description": "A kit that helps an AI draw beautiful, correct draw.io diagrams: a ground-truth AWS stencil catalog, layout principles, and a validator. Exposed via an MCP server + CLI.",
  "type": "module",
  "bin": {
    "drawio-ai": "./src/cli.mjs"
  },
  "scripts": {
    "mcp": "node src/mcp-server.mjs",
    "cli": "node src/cli.mjs",
    "test": "node --test",
    "gen:catalog": "python3.11 scripts/ingest_index.py"
  },
  "files": [
    "src", "catalog", "data", "rules", "vendor", "scripts", "examples",
    "SKILL.md", "README.md", "THIRD_PARTY_NOTICES.md", ".nvmrc", ".python-version"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
